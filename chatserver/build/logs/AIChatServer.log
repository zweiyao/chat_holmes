## 附：代码结构提示 (伪代码)

```python
def solveNQueens(n):
    # 初始化结果列表
    solutions = []
    
    # 定义一个递归函数进行回溯
    def backtrack(row, cols, diag1, diag2):
        # 如果已经放置完所有皇后 (row == n)
        if row == n:
            solutions.append(current_board)
            return
        
        # 遍历每一列
        for col in range(n):
            # 检查当前位置是否合法
            # cols & (1 << col) : 检查列是否被占用
            # diag1 & (1 << (row - col)) : 检查副对角线
            # diag2 & (1 << (row + col)) : 检查主对角线
            if not (cols & (1 << col)) and not (diag1 & (1 << (row - col))) and not (diag2 & (1 << (row + col))):
                # 标记当前位置为占用
                cols |= (1 << col)
                diag1 |= (1 << (row - col))
                diag2 |= (1 << (row + col))
                
                # 递归处理下一行
                backtrack(row + 1, cols, diag1, diag2)
                
                # 回溯：取消标记
                cols &= ~(1 << col)
                diag1 &= ~(1 << (row - col))
                diag2 &= ~(1 << (row + col))

    # 调用回溯函数
    backtrack(0, 0, 0, 0)
    return len(solutions)
```

